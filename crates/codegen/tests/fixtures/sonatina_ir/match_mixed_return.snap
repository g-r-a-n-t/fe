target = "evm-ethereum-osaka"

type @layout_0 = enum {
    #A,
    #B,
};

func private %f(v0.objref<@layout_0>) -> i256 {
    block0:
        jump block1;

    block1:
        v2.@layout_0 = obj.load v0;
        v3.enumtag(@layout_0) = enum.tag v2;
        br_table v3 (0.enumtag(@layout_0) block3) (1.enumtag(@layout_0) block4);

    block2:
        return 2.i256;

    block3:
        return 0.i256;

    block4:
        jump block2;
}

func private %main() -> i256 {
    block0:
        jump block1;

    block1:
        v0.@layout_0 = enum.make @layout_0 #B;
        v1.objref<@layout_0> = obj.alloc @layout_0;
        v2.enumtag(@layout_0) = enum.tag v0;
        br_table v2 block3 (0.enumtag(@layout_0) block4) (1.enumtag(@layout_0) block5);

    block2:
        v5.i256 = call %f v1;
        return v5;

    block3:
        unreachable;

    block4:
        enum.set_tag v1 #A;
        jump block2;

    block5:
        enum.set_tag v1 #B;
        jump block2;
}

func private %main_root() {
    block0:
        jump block1;

    block1:
        v0.i256 = call %main;
        evm_stop;
}


object @main {
    section main {
        entry %main_root;
    }
}
