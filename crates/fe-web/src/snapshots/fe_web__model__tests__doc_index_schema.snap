        },
        "rich_signature": {
          "description": "Rich signature with embedded links (for rendering)",
          "items": {
            "$ref": "#/definitions/SignaturePart"
          },
          "type": "array"
        },
        "sig_scope": {
          "description": "SCIP scope path for this signature (set during enrich_signatures)",
          "type": [
            "string",
            "null"
          ]
        },
        "signature": {
          "description": "The item's signature/definition (plain text for backward compat)",
