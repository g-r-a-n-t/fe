use core::abi::Abi
use core::abi::ByteInput
use core::num::IntDowncast
use std::abi::Sol
use std::abi::SolDecoder
use std::abi::SolEncoder
use std::abi::sol
use std::evm::Address
use std::evm::Call
use std::evm::Create
use std::evm::Evm

pub struct TinyAbi {}
pub struct ShortAbi {}

impl Abi for TinyAbi {
    type Selector = u8
    type Decoder = SolDecoder
    type Encoder = SolEncoder
    const SELECTOR_SIZE: u256 = 1

    fn selector_from_prefix(_ prefix: u256) -> Self::Selector {
        (prefix >> 248).downcast_unchecked()
    }

    fn decode_bool_word(_ word: u256) -> bool {
        Sol::decode_bool_word(word)
    }
    fn decode_u8_word(_ word: u256) -> u8 {
        Sol::decode_u8_word(word)
    }
    fn decode_u16_word(_ word: u256) -> u16 {
        Sol::decode_u16_word(word)
    }
    fn decode_u32_word(_ word: u256) -> u32 {
        Sol::decode_u32_word(word)
    }
    fn decode_u64_word(_ word: u256) -> u64 {
        Sol::decode_u64_word(word)
    }
    fn decode_u128_word(_ word: u256) -> u128 {
        Sol::decode_u128_word(word)
    }
    fn decode_i8_word(_ word: u256) -> i8 {
        Sol::decode_i8_word(word)
    }
    fn decode_i16_word(_ word: u256) -> i16 {
        Sol::decode_i16_word(word)
    }
    fn decode_i32_word(_ word: u256) -> i32 {
        Sol::decode_i32_word(word)
    }
    fn decode_i64_word(_ word: u256) -> i64 {
        Sol::decode_i64_word(word)
    }
    fn decode_i128_word(_ word: u256) -> i128 {
        Sol::decode_i128_word(word)
    }
    fn decode_error() -> ! {
        Sol::decode_error()
    }

    fn decoder_new<I: ByteInput>(_ input: own I) -> Self::Decoder<I> {
        SolDecoder::new(input)
    }

    fn decoder_with_base<I: ByteInput>(_ input: own I, _ base: u256) -> Self::Decoder<I> {
        SolDecoder::with_base(input, base)
    }

    fn encoder_new(_ size: u256) -> Self::Encoder {
        SolEncoder::new(size)
    }
    fn store_word(ptr: u256, value: u256) {
        Sol::store_word(ptr: ptr, value: value)
    }
}

impl Abi for ShortAbi {
    type Selector = u16
    type Decoder = SolDecoder
    type Encoder = SolEncoder
    const SELECTOR_SIZE: u256 = 2

    fn selector_from_prefix(_ prefix: u256) -> Self::Selector {
        (prefix >> 240).downcast_unchecked()
    }

    fn decode_bool_word(_ word: u256) -> bool {
        Sol::decode_bool_word(word)
    }
    fn decode_u8_word(_ word: u256) -> u8 {
        Sol::decode_u8_word(word)
    }
    fn decode_u16_word(_ word: u256) -> u16 {
        Sol::decode_u16_word(word)
    }
    fn decode_u32_word(_ word: u256) -> u32 {
        Sol::decode_u32_word(word)
    }
    fn decode_u64_word(_ word: u256) -> u64 {
        Sol::decode_u64_word(word)
    }
    fn decode_u128_word(_ word: u256) -> u128 {
        Sol::decode_u128_word(word)
    }
    fn decode_i8_word(_ word: u256) -> i8 {
        Sol::decode_i8_word(word)
    }
    fn decode_i16_word(_ word: u256) -> i16 {
        Sol::decode_i16_word(word)
    }
    fn decode_i32_word(_ word: u256) -> i32 {
        Sol::decode_i32_word(word)
    }
    fn decode_i64_word(_ word: u256) -> i64 {
        Sol::decode_i64_word(word)
    }
    fn decode_i128_word(_ word: u256) -> i128 {
        Sol::decode_i128_word(word)
    }
    fn decode_error() -> ! {
        Sol::decode_error()
    }

    fn decoder_new<I: ByteInput>(_ input: own I) -> Self::Decoder<I> {
        SolDecoder::new(input)
    }

    fn decoder_with_base<I: ByteInput>(_ input: own I, _ base: u256) -> Self::Decoder<I> {
        SolDecoder::with_base(input, base)
    }

    fn encoder_new(_ size: u256) -> Self::Encoder {
        SolEncoder::new(size)
    }
    fn store_word(ptr: u256, value: u256) {
        Sol::store_word(ptr: ptr, value: value)
    }
}

const TINY_ALIAS: u8 = 0x7e

const fn tiny_pick() -> u8 {
    0x42
}

const fn tiny_identity(_ selector: u8) -> u8 {
    selector
}

#[abi = TinyAbi]
msg TinyLiteralMsg {
    #[selector = 0x2a]
    Literal,
}

#[abi = TinyAbi]
msg TinyConstMsg {
    #[selector = TINY_ALIAS]
    ConstAlias,
}

#[abi = TinyAbi]
msg TinyFnMsg {
    #[selector = tiny_pick()]
    PickedByFn,

    #[selector = tiny_identity(0x33)]
    PassedThroughFn,
}

#[abi = TinyAbi]
msg TinyOneByte {
    #[selector = 0x01]
    One,
}

#[abi = TinyAbi]
msg TinyBareMsg {
    #[selector = 0x55]
    Bare,
}

#[abi = TinyAbi]
msg TinyArgsMsg {
    #[selector = 0x10]
    Set { value: u256 },

    #[selector = 0x11]
    Add { a: u256, b: u256 } -> u256,
}

#[abi = ShortAbi]
msg ShortMsg {
    #[selector = 0xbeef]
    Short,
}

#[abi = ShortAbi]
msg ShortArgsMsg {
    #[selector = 0xabcd]
    Set { value: u256 },
}

msg SolMsg {
    #[selector = 0x00000001]
    SolOne,

    #[selector = sol("solSet()")]
    SolSet,

    #[selector = sol("last()")]
    Last -> u256,
}

pub contract SelectorTarget {
    mut last: u256,

    recv TinyLiteralMsg {
        Literal uses (mut last) {
            last = 42
        }
    }

    recv TinyConstMsg {
        ConstAlias uses (mut last) {
            last = 126
        }
    }

    recv TinyFnMsg {
        PickedByFn uses (mut last) {
            last = 66
        }
        PassedThroughFn uses (mut last) {
            last = 51
        }
    }

    recv TinyOneByte {
        One uses (mut last) {
            last = 1
        }
    }

    recv ShortMsg {
        Short uses (mut last) {
            last = 48879
        }
    }

    recv TinyArgsMsg {
        Set { value } uses (mut last) {
            last = value
        }

        Add { a, b } -> u256 uses (mut last) {
            let sum = a + b
            last = sum
            sum
        }
    }

    recv ShortArgsMsg {
        Set { value } uses (mut last) {
            last = value
        }
    }

    recv TinyBareMsg {
        Bare uses (mut last) {
            last = 85
        }
    }

    recv SolMsg {
        SolOne uses (mut last) {
            last = 1001
        }
        SolSet uses (mut last) {
            last = 2002
        }
        Last -> u256 uses (last) {
            last
        }
    }
}

fn assert_last(addr: Address, expected: u256) uses (evm: mut Evm) {
    let actual: u256 = with (Call = evm) {
        addr.call(SolMsg::Last {})
    }
    assert(actual == expected)
}

#[test]
fn custom_abi_selectors_dispatch_and_call() uses (evm: mut Evm) {
    let target = evm.create2<SelectorTarget>(value: 0, args: (), salt: 0)

    with (Call = evm) {
        target.call(TinyLiteralMsg::Literal {})
        assert_last(addr: target, expected: 42)

        target.call(TinyConstMsg::ConstAlias {})
        assert_last(addr: target, expected: 126)

        target.call(TinyFnMsg::PickedByFn {})
        assert_last(addr: target, expected: 66)

        target.call(TinyFnMsg::PassedThroughFn {})
        assert_last(addr: target, expected: 51)

        target.call(ShortMsg::Short {})
        assert_last(addr: target, expected: 48879)

        target.call(TinyBareMsg::Bare {})
        assert_last(addr: target, expected: 85)

        target.call(TinyOneByte::One {})
        assert_last(addr: target, expected: 1)

        target.call(SolMsg::SolOne {})
        assert_last(addr: target, expected: 1001)

        target.call(SolMsg::SolSet {})
        assert_last(addr: target, expected: 2002)

        target.call(TinyArgsMsg::Set { value: 9999 })
        assert_last(addr: target, expected: 9999)

        let sum: u256 = target.call(TinyArgsMsg::Add { a: 7, b: 35 })
        assert(sum == 42)
        assert_last(addr: target, expected: 42)

        target.call(ShortArgsMsg::Set { value: 123456 })
        assert_last(addr: target, expected: 123456)
    }
}
